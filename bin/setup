#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def check_ruby_version!
  required = Gem::Version.new("3.3.0")
  current = Gem::Version.new(RUBY_VERSION)

  if current < required
    abort "Ruby 3.3+ is required (you have #{RUBY_VERSION}). Please install a newer Ruby and try again."
  end

  puts "✓ Ruby #{RUBY_VERSION}"
end

def check_sqlite3!
  unless system("sqlite3 --version > /dev/null 2>&1")
    abort "SQLite3 is required but not found. Please install it and try again."
  end

  version = `sqlite3 --version`.strip.split.first
  puts "✓ SQLite3 #{version}"
end

FileUtils.chdir APP_ROOT do
  puts "== Checking prerequisites =="
  check_ruby_version!
  check_sqlite3!

  puts "\n== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts ""
  puts "========================================="
  puts "  All set! You're ready to go."
  puts ""
  puts "  Start the server:  bin/rails server"
  puts "  Run tests:         bin/rails test"
  puts "========================================="
end
